IMAGE_REPOSITORY=ghcr.io/owner/elettra-api
IMAGE_TAG=sha-change-me
STAGING_DOMAIN=api-staging.example.com

DJANGO_SETTINGS_MODULE=config.settings.base
DJANGO_SECRET_KEY=change-me-generate-a-long-secret
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=api-staging.example.com,web
APP_BASE_URL=https://api-staging.example.com
WEB_APP_BASE_URL=https://web-staging.example.com
CORS_ALLOWED_ORIGINS=https://web-staging.example.com
CSRF_TRUSTED_ORIGINS=https://api-staging.example.com,https://web-staging.example.com
SECURE_SSL_REDIRECT=true
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true

POSTGRES_DB=elettra_ng_staging
POSTGRES_USER=elettra
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_TASK_ALWAYS_EAGER=false

AWS_ACCESS_KEY_ID=minio
AWS_SECRET_ACCESS_KEY=change-me-minio
AWS_STORAGE_BUCKET_NAME=app-media
AWS_S3_ENDPOINT_URL=http://minio:9000
AWS_S3_REGION_NAME=us-east-1
AWS_S3_ADDRESSING_STYLE=path
AWS_DEFAULT_ACL=
AWS_QUERYSTRING_AUTH=true
AWS_S3_FILE_OVERWRITE=false

MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=change-me-minio-root
MINIO_HOST=minio
MINIO_PORT=9000

EMAIL_HOST=mailpit
EMAIL_PORT=1025
EMAIL_USE_TLS=false
EMAIL_USE_SSL=false
DEFAULT_FROM_EMAIL=noreply@api-staging.example.com
ORGANIZATION_INVITATION_TTL_DAYS=14

JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=14
JWT_ROTATE_REFRESH_TOKENS=true
JWT_BLACKLIST_AFTER_ROTATION=true

AI_PROVIDER=local
AI_DAILY_MESSAGE_LIMIT_PER_USER=20
AI_DAILY_TOKEN_LIMIT_PER_USER=20000
AI_DAILY_ESTIMATED_COST_LIMIT_PER_USER=0
AI_MONTHLY_ESTIMATED_COST_LIMIT_PER_ORGANIZATION=0
AI_CASE_DIAGNOSTIC_TURN_LIMIT=8
AI_DIAGNOSTIC_RECENT_MESSAGES_LIMIT=4
AI_CONTEXT_COMPACTION_MESSAGE_THRESHOLD=8
AI_ESTIMATED_INPUT_COST_PER_1K_TOKENS=0
AI_ESTIMATED_OUTPUT_COST_PER_1K_TOKENS=0
AI_OPENAI_MODEL=gpt-5.4-mini
OPENAI_API_KEY=
OPENAI_BASE_URL=
GUEST_SESSION_TTL_HOURS=72
GUEST_AI_TURN_LIMIT=2
GUEST_MESSAGE_LIMIT=8
GUEST_RATE_LIMIT_PER_IP_PER_DAY=5
NOTIFICATIONS_PUSH_DELIVERY_ENABLED=false

SENTRY_DSN=
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120
