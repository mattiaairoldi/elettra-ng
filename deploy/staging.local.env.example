# Copy to deploy/staging.local.env and keep it out of git.

STAGING_HOST=elettra.iapersonale.it
STAGING_USER=elettra
STAGING_PORT=22
STAGING_SSH_KEY=
STAGING_REMOTE_DIR=/home/elettra/elettra-ng
STAGING_PROJECT_NAME=elettra-staging

STAGING_DOMAIN=elettra.iapersonale.it
GIO_DOMAIN=gio.sitoistituzionale.ovh
GIO_SITE_ROOT=/var/www/html/giorgessi/www.giorgessi.it
STAGING_IMAGE_REPOSITORY=ghcr.io/owner/elettra-api
STAGING_IMAGE_TAG=sha-change-me
STAGING_APP_ENV_FILE=.env.staging
STAGING_UPLOAD_APP_ENV=true

# Run scripts/deploy/bootstrap-vps.sh as root before the first deploy.
STAGING_ROOT_USER=root
STAGING_STOP_LEGACY_SERVICES=true
STAGING_LEGACY_SUPERVISOR_PROGRAM=elettra
STAGING_DISABLE_SERVICES="postgresql nginx supervisor"
STAGING_COPY_ROOT_AUTHORIZED_KEYS=true

# Inline bootstrap in staging.sh is kept for simple sudo-capable users.
STAGING_BOOTSTRAP=false

# The elettra user is added to the docker group by bootstrap-vps.sh.
STAGING_REMOTE_SUDO=false
STAGING_DOCKER_SUDO=false

# Registry login is optional for public images.
STAGING_REGISTRY_SERVER=ghcr.io
STAGING_REGISTRY_USERNAME=
STAGING_REGISTRY_PASSWORD_CMD=
STAGING_REGISTRY_LOGIN_REQUIRED=false

# For first staging without a registry: build the image locally, then upload it
# via SSH as a Docker archive. When true, the deploy script skips compose pull.
STAGING_UPLOAD_IMAGE=false
STAGING_PULL=true
STAGING_RUN_MIGRATIONS=true
STAGING_SEED_DEMO=false
STAGING_RUN_HEALTHCHECK=true
STAGING_HEALTHCHECK_URL=https://elettra.iapersonale.it/api/v1/health
