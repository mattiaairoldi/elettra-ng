# Copy to deploy/staging.local.env and keep it out of git.

STAGING_HOST=203.0.113.10
STAGING_USER=ubuntu
STAGING_PORT=22
STAGING_SSH_KEY=
STAGING_REMOTE_DIR=/opt/elettra-ng-staging
STAGING_PROJECT_NAME=elettra-staging

STAGING_DOMAIN=api-staging.example.com
STAGING_IMAGE_REPOSITORY=ghcr.io/owner/elettra-api
STAGING_IMAGE_TAG=sha-change-me
STAGING_APP_ENV_FILE=.env.staging
STAGING_UPLOAD_APP_ENV=true

# Set true only when the remote host still needs Docker installed.
STAGING_BOOTSTRAP=false

# Use sudo for Docker and /opt directory management on a standard Ubuntu VPS.
STAGING_REMOTE_SUDO=true
STAGING_DOCKER_SUDO=true

# Registry login is optional for public images.
STAGING_REGISTRY_SERVER=ghcr.io
STAGING_REGISTRY_USERNAME=
STAGING_REGISTRY_PASSWORD_CMD=
STAGING_REGISTRY_LOGIN_REQUIRED=false

STAGING_PULL=true
STAGING_RUN_MIGRATIONS=true
STAGING_SEED_DEMO=false
STAGING_RUN_HEALTHCHECK=true
STAGING_HEALTHCHECK_URL=https://api-staging.example.com/api/v1/health
